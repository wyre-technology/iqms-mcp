{
  "name": "iqms-mcp",
  "version": "0.0.0-semantically-released",
  "description": "MCP server for IQMS / DELMIAworks (EnterpriseIQ) — read manufacturing ERP data via Oracle and post transactional updates via the WebAPI module",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "iqms-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "iqms",
    "delmiaworks",
    "enterpriseiq",
    "mcp",
    "msp",
    "manufacturing",
    "erp",
    "oracle",
    "model-context-protocol"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/iqms-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@wyre-technology/node-iqms": "github:wyre-technology/node-iqms#main"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^26.0.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
